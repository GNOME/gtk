msgstr "Не могу да поставим податке оставе. Није успела функција „OpenClipboard()“: 0×%lx."

#: gdk/win32/gdkclipdrop-win32.c:836
#, c-format
msgid "Cannot get clipboard data. GlobalLock(0x%p) failed: 0x%lx."
msgstr "Не могу да добавим податке оставе. Није успела функција „GlobalLock(0×%p)“: 0×%lx."

#: gdk/win32/gdkclipdrop-win32.c:847
