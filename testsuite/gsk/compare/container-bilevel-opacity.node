mask {
  source: container {
    color {
      bounds: 0 0 50 50;
      color: rgb(255,0,0);
    }
    color {
      bounds: 10 10 30 30;
      color: rgb(0,0,255);
    }
  }
  mask: container {
    color {
      bounds: 0 0 25 25;
      color: rgb(255,0,204);
    }
    color {
      bounds: 25 25 25 25;
      color: rgba(255,255,255,0.333333);
    }
  }
}
